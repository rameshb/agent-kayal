{
  "name": "pi-teams-agent",
  "version": "0.1.0",
  "description": "Desktop AI agent runtime for Microsoft Teams using Pi SDK + Electron",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "tsc && cd renderer && npm run build",
    "build:main": "tsc",
    "build:renderer": "cd renderer && npm run build",
    "dev": "npm run build && electron .",
    "dev:server": "tsx watch src/server.ts",
    "dev:renderer": "cd renderer && npm run dev",
    "start": "electron .",
    "setup": "npm install && bash scripts/setup-packages.sh",
    "setup:packages": "bash scripts/setup-packages.sh",
    "setup:auth": "npx @softeria/ms-365-mcp-server --org-mode --login",
    "postinstall": "cd renderer && npm install",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "clean": "rm -rf dist/ release/ renderer/dist/"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/openai": "^3.0.48",
    "@azure/msal-node": "^2.16.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@mariozechner/pi-agent-core": "^0.62.0",
    "@mariozechner/pi-ai": "^0.62.0",
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "ai": "^6.0.138",
    "dotenv": "^16.4.7",
    "electron-store": "^10.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.yourcompany.pi-teams-agent",
    "productName": "Pi Teams Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/dist/**/*",
      "workspace/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "renderer/dist",
        "to": "renderer"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Office"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
