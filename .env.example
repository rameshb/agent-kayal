# ─── Azure AD App Registration ───
# Register once at Azure Portal > Azure AD > App registrations
AZURE_CLIENT_ID=your-app-client-id
AZURE_TENANT_ID=your-directory-tenant-id

# ─── Agent Identity ───
# The display name used to detect @mentions in Teams
AGENT_NAME=Pi Agent

# ─── LLM Provider (at least one required) ───
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# ─── Agent Defaults ───
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-20250514

# ─── Skills API Keys ───
# Brave Search API key (for web search skill, get at brave.com/search/api)
# BRAVE_API_KEY=BSA-...

# ─── Server (for desktop chat UI) ───
PORT=3978
HOST=127.0.0.1

# ─── Workspace ───
WORKSPACE_DIR=./workspace
SESSION_DIR=./workspace/.sessions

# ─── Agent Sandbox ───
# The directory name where the agent can read/write files.
# Created inside WORKSPACE_DIR. All Pi tools are scoped to this path.
AGENT_WORKSPACE_NAME=my_pi_agent

# ─── Polling ───
# How often to check Teams for new messages (ms)
POLL_INTERVAL_MS=2000

# ─── Security ───
# Comma-separated Azure AD user IDs allowed to interact
ALLOWED_USERS=
# Max agent actions per hour per user (0 = unlimited)
RATE_LIMIT_PER_HOUR=60

# ─── Logging ───
LOG_LEVEL=info
